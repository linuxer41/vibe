PORT=5000

# Media directory path (default: ./media)
# MEDIA_DIR=./media

# Cache directory path (default: ./cache)
# CACHE_DIR=./cache

# --- S3 configuration (optional) ---
# Set S3_BUCKET to enable S3 storage instead of local filesystem
# S3_BUCKET=vibe-media
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.custom-endpoint.com
# S3_FORCE_PATH_STYLE=true
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_PUBLIC_URL=https://cdn.vibe-app.com
